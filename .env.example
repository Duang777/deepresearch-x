# Providers
SEARCH_PROVIDER=duckduckgo
LLM_PROVIDER=heuristic
OPENAI_MODEL=gpt-4.1-mini

# Web reader enrichment
ENABLE_PAGE_READER=true
MAX_PAGE_FETCH_PER_LOOP=3
PAGE_FETCH_WORKERS=4
MAX_PAGE_CHARS=12000
READER_TIMEOUT_SECONDS=8

# Optional if using OpenAI provider
# OPENAI_API_KEY=your-key

# Cost estimation knobs (USD per 1k tokens)
CHEAP_MODEL_COST_PER_1K=0.0006
EXPENSIVE_MODEL_COST_PER_1K=0.005

# Memory/session system (DeerFlow-style + optional OpenViking adapter)
ENABLE_MEMORY=true
MEMORY_BACKEND=sqlite
MEMORY_SQLITE_PATH=outputs/memory_store.db
MEMORY_BUDGET_TOKENS=280
MEMORY_SCOPE=hybrid
MEMORY_QUEUE_WAIT_MS=220
# OpenViking is optional. If unreachable, adapter falls back to SQLite.
OPENVIKING_BASE_URL=http://127.0.0.1:8100
OPENVIKING_TIMEOUT_SECONDS=0.8

# Strict mode fallback policy (recommended for real data integrity)
ALLOW_SEARCH_MOCK_FALLBACK=false
ALLOW_LLM_HEURISTIC_FALLBACK=false

# Memory capacity governance
MEMORY_TTL_HOURS=336
MEMORY_MAX_GLOBAL_FACTS=600
MEMORY_MAX_SESSION_FACTS=250

# Optional semantic evidence alignment (requires sentence-transformers)
ENABLE_SEMANTIC_ALIGNMENT=false
SEMANTIC_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
SEMANTIC_WEIGHT=0.6
KEYWORD_WEIGHT=0.4

# UI defaults
DEFAULT_LOOPS=3
DEFAULT_TOP_K=6
